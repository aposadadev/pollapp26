# Firebase configuration (Client-side)
# Copy this file to .env and fill in your Firebase project values.
# Get these from: Firebase Console → Project Settings → General → Your apps

NUXT_PUBLIC_FIREBASE_API_KEY=
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NUXT_PUBLIC_FIREBASE_PROJECT_ID=
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NUXT_PUBLIC_FIREBASE_APP_ID=

# Realtime Database URL (required for live rankings)
# Format: https://<project-id>-default-rtdb.firebaseio.com
NUXT_PUBLIC_FIREBASE_DATABASE_URL=

# ─────────────────────────────────────────────────────────────────
# Firebase Admin SDK (para scripts/seed.ts)
# Get these from: Firebase Console → Project Settings → Service accounts
# Generate a new private key and copy the values here
# ─────────────────────────────────────────────────────────────────

FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
