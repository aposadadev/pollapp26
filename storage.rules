rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Team logos — cualquier usuario autenticado puede leer
    // Solo admins pueden subir/eliminar
    match /teams/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Tournament assets — lectura pública, escritura solo admin
    match /tournaments/{allPaths=**} {
      allow read;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
