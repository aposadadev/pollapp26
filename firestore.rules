rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() && request.auth.token.admin == true;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    // El usuario puede leer/escribir su propio perfil; admins leen todo.
    // Incluye fcmTokens y notificationPrefs (escritura por el propio usuario).

    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Teams ─────────────────────────────────────────────────────────────────
    // Lectura pública (datos del torneo). Solo admins escriben.

    match /teams/{teamId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Matches ───────────────────────────────────────────────────────────────
    // Lectura pública (datos del torneo). Solo admins escriben.

    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Groups ────────────────────────────────────────────────────────────────
    // Cualquier usuario autenticado puede leer. Admins y propietario pueden crear/editar.

    match /groups/{groupId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAdmin() || isOwner(resource.data.ownerId);
      allow delete: if isAdmin();
    }

    // ── Boards ────────────────────────────────────────────────────────────────
    // El dueño del board puede leerlo. Todos los autenticados pueden leer boards
    // de su grupo para ver posiciones. Solo admins pueden activar/eliminar.

    match /boards/{boardId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == request.resource.data.userId;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Predictions ───────────────────────────────────────────────────────────
    // El dueño del board puede leer y editar sus predicciones.
    // Todos los autenticados pueden leer predicciones de su grupo (para vista de partido).
    // Solo Firebase Functions (admin SDK) actualiza los puntos.
    // Las predicciones se bloquean 30 minutos antes del inicio del partido.

    match /predictions/{predId} {
      // Helper: obtiene la fecha del partido asociado a esta predicción
      function matchDate() {
        return get(/databases/$(database)/documents/matches/$(resource.data.matchId)).data.date;
      }

      // Helper: verifica que el partido aún no se haya cerrado
      function matchNotClosed() {
        return get(/databases/$(database)/documents/matches/$(resource.data.matchId)).data.isClosed != true;
      }

      // Helper: faltan más de 30 min (1800000 ms) para el inicio
      function beforeCutoff() {
        return request.time < matchDate() - duration.value(30, 'm');
      }

      // Helper: el usuario es dueño del board de esta predicción
      function isBoardOwner() {
        return isOwner(get(/databases/$(database)/documents/boards/$(resource.data.boardId)).data.userId);
      }

      allow read: if isAuth();
      allow create: if isAdmin(); // Las crea activateBoard (admin SDK)
      allow update: if (isAuth() && isBoardOwner() && matchNotClosed() && beforeCutoff()) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Counters (internal, server-side only) ────────────────────────────────
    // Managed exclusively by Cloud Functions via Admin SDK (requestBoard callable).
    // Clients must NOT read or write this collection; board creation goes through
    // the requestBoard callable which runs with elevated server privileges.

    match /_counters/{counterId} {
      allow read, write: if false;
    }

  }
}
